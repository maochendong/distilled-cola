# ── LLM API 配置 ──
# DeepSeek（主，用于问答/标注/质检）
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI（备选，用于 Embedding + 图片文字识别 Vision）
OPENAI_API_KEY=sk-your-openai-key

# AnySearch（实时网络搜索，用于获取当前行情/政策/价格数据）
# 注册获取: https://anysearch.com/console/api-keys
ANYSEARCH_API_KEY=as_sk_your_key_here

# ── 模型选择 ──
STUDENT_MODEL=deepseek-v4-flash
TEACHER_MODEL=deepseek-v4-pro
EMBEDDING_MODEL=text-embedding-3-small

# ── 路径 ──
DATA_DIR=./data
CHROMA_DB_PATH=./data/embeddings/chroma_db

# ── 处理参数 ──
WHISPER_MODEL=large-v3
SEGMENT_MIN_LENGTH=100
SEGMENT_MAX_LENGTH=2000
TOP_K=5
HYBRID_ALPHA=0.4

# ── 知识库集合 ──
KNOWLEDGE_COLLECTION=sh_knowledge
REASONING_COLLECTION=sh_reasoning_chains
